              "raw": "{\n  \"numeroPedido\": \"PED-006\",\n  \"clienteNome\": \"Fernanda Lima\",\n  \"clienteEmail\": \"fernanda.lima@email.com\",\n  \"itens\": [\n    { \"produtoId\": 1, \"quantidade\": 1 },\n    { \"produtoId\": 3, \"quantidade\": 2 },\n    { \"produtoId\": 5, \"quantidade\": 1 }\n  ]\n}"
