          }
        },
        {
          "name": "DELETE — Cancelar pedido",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{host}}/api/pedidos/5", "host": ["{{host}}"], "path": ["api","pedidos","5"] }
          }
        },
        {
          "name": "DELETE — Pedido não encontrado (404)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{host}}/api/pedidos/999", "host": ["{{host}}"], "path": ["api","pedidos","999"] }
