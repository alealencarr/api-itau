          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroPedido\": \"PED-007\",\n  \"clienteNome\": \"Carlos Melo\",\n  \"clienteEmail\": \"carlos.melo@email.com\",\n  \"itens\": [\n    { \"produtoId\": 2, \"quantidade\": 2 },\n    { \"produtoId\": 2, \"quantidade\": 3 }\n  ]\n}"
            },
            "url": { "raw": "{{host}}/api/pedidos", "host": ["{{host}}"], "path": ["api","pedidos"] }
          }
        },
