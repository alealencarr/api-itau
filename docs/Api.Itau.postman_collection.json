              "mode": "raw",
              "raw": "{\n  \"nome\": \"Produto Inválido\",\n  \"preco\": 0,\n  \"estoque\": 10\n}"
            },
            "url": { "raw": "{{host}}/api/produtos", "host": ["{{host}}"], "path": ["api","produtos"] }
          }
        },
