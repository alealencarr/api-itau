        {
          "name": "GET — Listar todos os pedidos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{host}}/api/pedidos", "host": ["{{host}}"], "path": ["api","pedidos"] }
