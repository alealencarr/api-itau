          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"numeroPedido\": \"PED-009\",\n  \"clienteNome\": \"Teste Email\",\n  \"clienteEmail\": \"email-invalido\",\n  \"itens\": [\n    { \"produtoId\": 1, \"quantidade\": 1 }\n  ]\n}"
            },
            "url": { "raw": "{{host}}/api/pedidos", "host": ["{{host}}"], "path": ["api","pedidos"] }
          }
        },
        {
          "name": "POST — Criar pedido (400) — sem itens",
