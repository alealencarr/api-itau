          "name": "DELETE — Desativar produto (soft delete)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{host}}/api/produtos/10", "host": ["{{host}}"], "path": ["api","produtos","10"] }
          }
        },
        {
          "name": "DELETE — Produto não encontrado (404)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{host}}/api/produtos/999", "host": ["{{host}}"], "path": ["api","produtos","999"] }
          }
        }
      ]
    },
    {
      "name": "📦 Pedidos",
