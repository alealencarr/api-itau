{
  "info": {
    "name": "API Itaú — Catálogo & Pedidos",
    "description": "Collection completa com todos os endpoints, payloads e cenários de erro.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "host", "value": "http://localhost:5160", "type": "string" }
  ],
  "item": [
    {
      "name": "🛍️ Produtos",
      "item": [
        {
          "name": "GET — Listar todos os produtos ativos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{host}}/api/produtos", "host": ["{{host}}"], "path": ["api","produtos"] }
          }
        },
        {
          "name": "GET — Produto por ID (existente)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{host}}/api/produtos/1", "host": ["{{host}}"], "path": ["api","produtos","1"] }
          }
        },
        {
          "name": "GET — Produto por ID (404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{host}}/api/produtos/999", "host": ["{{host}}"], "path": ["api","produtos","999"] }
          }
        },
        {
          "name": "POST — Criar produto válido",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Smartphone Samsung Galaxy S24\",\n  \"descricao\": \"Smartphone 256GB 12GB RAM câmera 200MP\",\n  \"preco\": 3499.90,\n  \"estoque\": 20\n}"
            },
            "url": { "raw": "{{host}}/api/produtos", "host": ["{{host}}"], "path": ["api","produtos"] }
          }
        },
        {
          "name": "POST — Criar produto sem descrição (opcional)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Cabo USB-C 2m\",\n  \"preco\": 39.90,\n  \"estoque\": 100\n}"
            },
            "url": { "raw": "{{host}}/api/produtos", "host": ["{{host}}"], "path": ["api","produtos"] }
          }
        },
        {
          "name": "POST — Criar produto (400) — nome vazio",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
