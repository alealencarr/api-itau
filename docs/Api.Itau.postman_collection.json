              "mode": "raw",
              "raw": "{\n  \"nome\": \"Notebook Dell Inspiron Atualizado\",\n  \"descricao\": \"Notebook Dell i9 32GB RAM 1TB SSD\",\n  \"preco\": 6499.99,\n  \"estoque\": 5\n}"
            },
            "url": { "raw": "{{host}}/api/produtos/1", "host": ["{{host}}"], "path": ["api","produtos","1"] }
          }
        },
        {
          "name": "PUT — Atualizar produto (404)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Produto Fantasma\",\n  \"preco\": 99.90,\n  \"estoque\": 5\n}"
